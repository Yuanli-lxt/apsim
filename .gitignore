# 默认忽略所有文件，避免把 APSIM 大量输出误提交。
*

# 允许 Git 继续向下扫描目录。
!*/

# 项目说明和索引文档。
!.gitignore
!/PROJECT_STRUCTURE.md

# Python 代码统一放在 scripts/；Sobol 流程脚本仍保留在 sobol/scripts/。
!/scripts/
!/scripts/*.py
!/sobol/
!/sobol/scripts/
!/sobol/scripts/*.py

# results/ 只保留索引，不追踪大型结果文件。
!/results/
/results/*
!/results/README.md
!/results/results_manifest.json

# assimilation/ 保留筛选后的脚本、配置、源数据、文档和关键测试结果；
# 继续忽略 pycache、APSIM 中间搜索目录和可再生成的大批量运行文件。
!/assimilation/
!/assimilation/README.md
!/assimilation/migration_manifest.json
!/assimilation/scripts/
!/assimilation/scripts/**/*.py
!/assimilation/configs/
!/assimilation/configs/**/*.json
!/assimilation/data/
!/assimilation/data/**/*.csv
!/assimilation/data/**/*.xls
!/assimilation/data/**/*.xlsx
!/assimilation/docs/
!/assimilation/docs/**/*.md
!/assimilation/test_results/
!/assimilation/test_results/**/*.csv
!/assimilation/test_results/**/*.json
!/assimilation/test_results/**/*.png
!/assimilation/test_results/**/*.apsim
!/assimilation/test_results/**/*.out
!/assimilation/test_results/**/*.sum
!/assimilation/test_results/**/*.sim
/assimilation/**/__pycache__/
/assimilation/**/var_evals/
/assimilation/**/step_*/

# 如后续有少量根目录脚本或 C/Shell 工具，可按需保留。
!/*.sh
!/*.c
