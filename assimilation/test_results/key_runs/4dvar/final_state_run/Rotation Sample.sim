    <component name="soil Water" executable="%apsim%/Model/SoilWat.dll" class="SoilWat">
      <executable name="%apsim%/Model/SoilWat.dll" version="1.0" />
      <initdata>
        <!--    ****************
      soilwat2_eeq_fac
      ****************
      -->
        <min_crit_temp units="oC" description="temperature below which eeq decreases (oC)">5.0</min_crit_temp>
        <max_crit_temp units="oC" description="temperature above which eeq increases (oC)">35.0</max_crit_temp>
        <!--    ******************************
      soilwat2_pot_evapotranspiration
      ******************************
      -->
        <max_albedo description="albedo at 100% green crop cover (0-1).">0.23</max_albedo>
        <!--  Bare soil albedo must not exceed this value.
      ***********************
      soilwat_evaporation
      *********************** <dms 7-95>
      -->
        <A_to_evap_fact description="converts residue specfic area 'A' to">0.44      </A_to_evap_fact>
        <!--    a coef. in exp effect on reducing
      pot. soil evap for wt. of mixed residues.
      0.44 = 0.00022/0.0005 DMS 1st approx. 6/95
      -->
        <canopy_eos_coef description="coef. in exp effect of canopy on">1.7       </canopy_eos_coef>
        <!--    reducing pot. soil evap.
      = 1.7 Adams, Arkin & Ritchie 1976
      ******************
      soilwat2_evap_init
      ******************
      -->
        <sw_top_crit description="critical sw ratio in top layer">0.9</sw_top_crit>
        <!--  below which stage 2 evaporation occurs
      -->
        <sumes1_max units="mm" description="upper limit of sumes1">100.0</sumes1_max>
        <sumes2_max units="mm" description="upper limit of sumes2">25.0</sumes2_max>
        <!--    ******************
      soilwat2_nflow
      ******************
      -->
        <solute_flow_eff description="efficiency of moving solute with flow (0-1)">1.0</solute_flow_eff>
        <!--    ******************
      soilwat2_nflux
      ******************
      -->
        <solute_flux_eff description="efficiency of moving solute with flux (0-1)">1.0</solute_flux_eff>
        <!--    ******************
      soilwat2_unsaturated_flow
      ******************
      -->
        <gravity_gradient description="soil water gradient due to gravitational">0.00002</gravity_gradient>
        <!--  pressure head
      ****************
      soilwat2_check_profile
      ****************
      -->
        <specific_bd units="g/cc" description="specific bulk density">2.65</specific_bd>
        <hydrol_effective_depth units="mm">450</hydrol_effective_depth>
        <mobile_solutes>no3 urea cl br org_n org_c_pool1 org_c_pool2 org_c_pool3</mobile_solutes>
        <immobile_solutes>nh4</immobile_solutes>
        <!--    ****************
      soilwat2_runoff_cover
      ****************
      -->
        <canopy_fact>1.0  1.0  0.0  0.0</canopy_fact>
        <canopy_fact_height units="mm">0  600  1800 30000</canopy_fact_height>
        <canopy_fact_default description="canopy factor to use if height is missing">0.5</canopy_fact_default>
        <!--  added for SOILWAT2 ver 1.4 Aug-97 DMS & PdV
      ****************
      soilwat2_evaporation
      ****************
      <8-97 dms&pdv>
      Ritchie (use with crops),
      Ken Rickert (use with GRASP),
      B&S
      actual soil evaporation methods
      -->
        <act_evap_method>ritchie</act_evap_method>
        <!-- act_evap_method = rickert
      act_evap_method = bs_a
      act_evap_method = bs_b
      ****************
      soilwat2_tillage
      **************** <8-97 dms&pdv>
      Mark Littleboy's tillage effect on runoff (used in PERFECT v2.0)
      Littleboy, Cogle, Smith, Yule & Rao (1996)  Soil management and production
      of alfisols in the SAT's I. Modelling the effects of soil management on runoff
      and erosion.  Aust. J. Soil Res. 34: 91-102.

      Tillage types that appear here must also be in residue2.ini under
      [standard.residue2.tillage] !

      Tillage reduces runoff potential (CN2) by g_tillage_cn_red (1st column below).
      After tillage, CN2 increases linearly with cumulative rain since tillage until
      g_tillage_cn_rain (column 2 below) has occured, ie roughness is smoothed out by rain.
      Example parameter values (Littleboy et al) are given below for shallow & deep tillage.
      Also, Nelsen et al (in press) had to reduce CN2 by 30 for ~ 30 days after tillage
      during the wet season in wet tropical Philipines to mimic measured runoff.
      -->
        <tillage>
          <!--  ________________________________________
         tillage         CN2        Cumulative
         type        reduction      rain to
         cease reduction
         (0-100)        (mm)
         ________________________________________
         -->
          <chisel>0.0           0.   </chisel>
          <disc>0.0           0.</disc>
          <tine>0.0           0.</tine>
          <blade>0.0           0.</blade>
          <planter>0.0           0.</planter>
          <burn>0.0           0.</burn>
          <spray>0.0           0.</spray>
        </tillage>
        <diffus_const>88.000</diffus_const>
        <diffus_slope>35.000</diffus_slope>
        <cn2_bare>73.000</cn2_bare>
        <cn_red>20.000</cn_red>
        <cn_cov>0.800</cn_cov>
        <salb>0.130</salb>
        <SummerCona>3.500</SummerCona>
        <WinterCona>2.000</WinterCona>
        <SummerU>6.000</SummerU>
        <WinterU>2.000</WinterU>
        <SummerDate>1-Nov</SummerDate>
        <WinterDate>1-Apr</WinterDate>
        <dlayer>100.000 100.000 100.000 100.000 100.000 100.000 100.000 100.000 100.000 100.000 100.000 100.000 100.000 100.000 100.000 100.000 </dlayer>
        <sat>0.335 0.361 0.371 0.319 0.330 0.330 0.328 0.326 0.324 0.322 0.320 0.318 0.317 0.316 0.315 0.314 </sat>
        <dul>0.205 0.196 0.189 0.192 0.200 0.202 0.205 0.206 0.207 0.208 0.209 0.210 0.212 0.213 0.214 0.215 </dul>
        <ll15>0.072 0.060 0.067 0.070 0.070 0.072 0.072 0.074 0.074 0.076 0.076 0.078 0.078 0.080 0.080 0.082 </ll15>
        <air_dry>0.036 0.030 0.034 0.035 0.035 0.036 0.036 0.037 0.037 0.038 0.038 0.039 0.039 0.040 0.040 0.041 </air_dry>
        <swcon>0.450 0.450 0.400 0.400 0.400 0.400 0.380 0.380 0.350 0.350 0.300 0.300 0.300 0.250 0.250 0.250 </swcon>
        <bd>1.360 1.293 1.293 1.374 1.374 1.380 1.380 1.390 1.390 1.400 1.400 1.410 1.410 1.420 1.420 1.430 </bd>
        <sw>0.205 0.196 0.189 0.192 0.200 0.202 0.205 0.206 0.207 0.208 0.209 0.210 0.086 0.080 0.080 0.082 </sw>
        <mwcon>0.400 0.400 0.300 0.300 0.300 0.300 0.300 0.300 0.300 0.300 0.300 0.300 0.300 0.300 0.300 0.300 </mwcon>
        <klat>0.030 0.030 0.030 0.030 0.030 0.030 0.020 0.020 0.020 0.020 0.010 0.010 0.010 0.010 0.010 0.010 </klat>
      </initdata>
    </component>
    <component name="soil Nitrogen" executable="%apsim%/Model/SoilN.dll" class="SoilN">
      <executable name="%apsim%/Model/SoilN.dll" version="1.0" />
      <initdata>
        <standard>
          <!-- Bounds  -->
          <fbiom_lb>0</fbiom_lb>
          <fbiom_ub>1</fbiom_ub>
          <finert_lb>0</finert_lb>
          <finert_ub>1</finert_ub>
          <cnrf_coeff description="coeff. to determine the magnitude">0.693  </cnrf_coeff>
          <!--  of C:N effects on decomposition of FOM ()
         -->
          <cnrf_optcn description="C:N above which decomposition rate">25.0   </cnrf_optcn>
          <!--  of FOM declines ()
         -->
          <ef_biom description="fraction of biomass C mineralized">0.4       </ef_biom>
          <!--  retained in system (0-1)
         -->
          <ef_fom description="fraction of FOM C mineralized">0.4        </ef_fom>
          <!--  retained in system (0-1)
         -->
          <ef_hum description="fraction of humic C mineralized">0.4        </ef_hum>
          <!--  retained in system (0-1)
         -->
          <ef_res description="fraction of residue C mineralized">0.4        </ef_res>
          <!--  retained in system (0-1)
         -->
          <fom_min description="minimum allowable FOM (kg/ha)">0.5       </fom_min>
          <fr_biom_biom description="fraction of retained biomass C">0.6  </fr_biom_biom>
          <!--  returned to biomass (0-1)
         -->
          <fr_fom_biom description="fraction of retained FOM C">0.9   </fr_fom_biom>
          <!--  transferred to biomass (0-1)
         -->
          <fr_res_biom description="fraction of retained residue C">0.9   </fr_res_biom>
          <!--  transferred to biomass (0-1)
         -->
          <fom_type>default manure  mucuna lablab shemp  stable </fom_type>
          <fr_carb description="carbohydrate fraction of FOM (0-1)">0.2      0.3     0.54        0.57    0.45   0.0 </fr_carb>
          <fr_cell description="cellulose fraction of FOM (0-1)">   0.7      0.3     0.37        0.37    0.47   0.1  </fr_cell>
          <fr_lign description="lignin fraction of FOM (0-1)">      0.1      0.4     0.09        0.06    0.08   0.9 </fr_lign>
          <oc2om_factor description="factor to convert organic carbon to">1.7  </oc2om_factor>
          <!--  organic matter ()
         -->
          <mcn description="C:N ratio of microbes ()">8.0           </mcn>
          <!-- dsg 200509 ****** the following constants are for (a) aerobic AND (b)anaerobic conditions ***** -->
          <opt_temp description="Soil temperature above which there">32.0  32.0   </opt_temp>
          <!--  is no further effect on mineralisation
         and nitrification (oC)
         -->
          <rd_biom description="potential rate of soil biomass">0.0081  0.004  </rd_biom>
          <!--  mineralization (per day)
         -->
          <rd_carb description="maximum rate constant for">0.2   0.1    </rd_carb>
          <!--  decomposition of FPool1 (0-1)
         -->
          <rd_cell description="maximum rate constant for">0.05  0.025    </rd_cell>
          <!--  decomposition of FPool2 (0-1)
         -->
          <rd_lign description="maximum rate constant for">0.0095   0.003  </rd_lign>
          <!--  decomposition of FPool3 (0-1)
         -->
          <rd_hum description="potential rate of humus">0.00015  0.00007  </rd_hum>
          <!--  mineralization (per day)
         -->
          <nh4ppm_min description="minimum allowable NH4 (ppm)">0.0    </nh4ppm_min>
          <no3ppm_min description="minimum allowable NO3 (ppm)">0.0    </no3ppm_min>
          <min_depth description="depth of soil from which N can be">100.    </min_depth>
          <!--  immobilised by decomposing surface
         residues (mm)
         ______________________________________________________________________-
         Specifying the water factor for Nitrogen Transformations is
         by referring to water content via an indexing system and linear interpolation
         between specified coordinates.
         (see example)

         1 |    ______
         |   /.     \                In this example
         .5 |  / .      -               wf_index = 0.0 0.5 1.0 2.0
         | /  .        \             wf_values= 0.0 1.0 1.0 0.25
         |/   .
         0 ______________________-
         LL       DUL   SAT
         =0       =1    =2
         -->
          <wfmin_index description="index specifying water content">0.0 0.5 1.0 2.0  </wfmin_index>
          <!--  for water factor for mineralization
         -->
          <wfmin_values description="value of water factor function">0.0 1.0 1.0 0.5  </wfmin_values>
          <!--  at given index values(mineralization)
         -->
          <wfnit_index description="index specifying water content">0.0 0.25 1.0 2.0  </wfnit_index>
          <!--  for water factor for nitrification
         -->
          <wfnit_values description="value of water factor function">0.0 1.0 1.0 0.0  </wfnit_values>
          <!--  at given index values(nitrification)
         ______________________________________________________________________-
         -->
          <nitrification_pot units="ppm" description="Soil Nitrification potential (ug NH4/g soil)">40.0</nitrification_pot>
          <nh4_at_half_pot units="ppm" description="NH4 concentration at half potential">90</nh4_at_half_pot>
          <!--  nitrification (Michaelis-Menton kinetics)
