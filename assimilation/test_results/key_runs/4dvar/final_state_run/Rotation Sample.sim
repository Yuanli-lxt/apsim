    <component name="RotationCounter" executable="%apsim%\Model\Manager2.dll" class="Manager2">
      <executable name="%apsim%/Model/Manager2.dll" version="1.0" />
      <initdata>
        <Manager2 />
        <ui />
        <text>using System; 
using System.Collections.Generic;
using ModelFramework; 

// Counts the number of times a rotation has completed (ie gone back to the starting point)

// Multi-paddock aware.
public class Script 
{ 
   [Link] public Simulation MySimulation;   
   [Output, Description("Number of times the rotation has cycled"), Units("n")] public int rotationNumber {
      get {setup(); return(rotationNumberD[currentPaddock()]);}
      set {}
   }

   private Dictionary&lt;string, int&gt; rotationNumberD = new Dictionary&lt;string, int&gt;();
   private Dictionary&lt;string, bool&gt; needsCheck = new Dictionary&lt;string, bool&gt;();
   private Dictionary&lt;string, string&gt; initialState = new Dictionary&lt;string, string&gt;();
   private void setup() {
      if (initialState.Keys.Count == 0) { OnStart_Simulation(); }
   }
   
   [EventHandler] public void OnStart_Simulation() { 
      if (initialState.Keys.Count == 0) {
         foreach (Paddock paddock in MySimulation.ChildPaddocks) 
         {
            string s = "";
            if (MySimulation.Get(paddock.Name + "_state", out s)) {
               initialState.Add(paddock.Name, s);
            } else {
               MySimulation.Get("currentstate", out s);
               initialState.Add(paddock.Name, s);
            }
            needsCheck.Add(paddock.Name, false);
            rotationNumberD.Add(paddock.Name, 0);
         }
      }
   }    
 
   [EventHandler] public void OnPrepare() { foreach (Paddock paddock in MySimulation.ChildPaddocks) { needsCheck[paddock.Name] = false; }}
   [EventHandler] public void OnTransition() { needsCheck[currentPaddock()] = true; } 
   [EventHandler] public void OnPost() { 
      foreach (Paddock paddock in MySimulation.ChildPaddocks) {
         if (needsCheck[paddock.Name])  { 
            string currentState = ""; 
            if (!MySimulation.Get(paddock.Name + "_state", out currentState))
               MySimulation.Get("currentstate", out currentState);
            if (currentState == initialState[paddock.Name])  
               rotationNumberD[paddock.Name]++; 
         } 
      }
   } 
   private string currentPaddock() {
      string result = "";
      MySimulation.Get("currentPaddock", out result);
      if (result != "")
         return(result);
      else
         return(MySimulation.ChildPaddocks[0].Name);
   }
} </text>
      </initdata>
    </component>
