<?xml version="1.0" encoding="utf-8"?>
<simulation name="Rotation Sample" executable="%apsim%/Model/ProtocolManager.dll">
  <executable name="%apsim%/Model/ProtocolManager.dll" version="1.0" />
  <component name="clock" executable="%apsim%\Model\Clock.dll" class="Clock">
    <executable name="%apsim%\Model\Clock.dll" version="1.0" />
    <initdata>
      <timestep_events>prepare init_step do_management run_one_step do_pasture_water process do_pasture_growth do_stock do_cashbook post end_step</timestep_events>
      <start_date type="date" description="Enter the start date of the simulation">01/10/2024</start_date>
      <end_date type="date" description="Enter the end date of the simulation">30/12/2025</end_date>
    </initdata>
  </component>
  <component name="met" executable="%apsim%\Model\Input.dll" class="Input.Metfile">
    <executable name="%apsim%\Model\Input.dll" version="1.0" />
    <initdata>
      <filename name="filename" input="yes">E:\A_data\p0-1-24-25.met</filename>
    </initdata>
  </component>
  <title>Rotation Sample</title>
  <system name="paddock" executable="%apsim%/Model/ProtocolManager.dll" class="ProtocolManager">
    <executable name="%apsim%/Model/ProtocolManager.dll" version="1.0" />
    <component name="Harvest" executable="%apsim%\Model\Report.dll" class="Report.Outputfile">
      <executable name="%apsim%\Model\Report.dll" version="1.0" />
      <initdata>
        <outputfile>Rotation Sample Harvest.out</outputfile>
        <title>Rotation Sample Harvest</title>
        <variable>dd/mm/yyyy as Date</variable>
        <variable>yield</variable>
        <variable>biomass</variable>
        <outputfrequency>harvesting</outputfrequency>
      </initdata>
    </component>
    <component name="Phases" executable="%apsim%\Model\Report.dll" class="Report.Outputfile">
      <executable name="%apsim%\Model\Report.dll" version="1.0" />
      <initdata>
        <outputfile>Rotation Sample Phases.out</outputfile>
        <title>Rotation Sample Phases</title>
        <variable>dd/mm/yyyy as Date</variable>
        <variable>Rain as Rainfall</variable>
        <variable>currentState</variable>
        <variable>rotationNumber</variable>
        <variable>simulation_days</variable>
        <variable>sw_dep() as SoilWater</variable>
        <variable>maize.Biomass as MaizeBio</variable>
        <variable>wheat.Biomass as WheatBio</variable>
        <variable>maize.Yield as MaizeYield</variable>
        <variable>wheat.Yield as WheatYield</variable>
        <variable>wheat.lai as wheatlai</variable>
        <outputfrequency>transition</outputfrequency>
        <outputfrequency>end_day</outputfrequency>
        <outputfrequency>harvesting</outputfrequency>
        <outputfrequency>harvesting</outputfrequency>
      </initdata>
    </component>
    <component name="accum" executable="%apsim%/Model/Accum.dll" class="Accum">
      <executable name="%apsim%/Model/Accum.dll" version="1.0" />
      <initdata>
        <accum_variables>rain[15]</accum_variables>
      </initdata>
    </component>
    <component name="Fertiliser" executable="%apsim%\Model\Fertiliser.dll" class="Fertiliser">
      <executable name="%apsim%\Model\Fertiliser.dll" version="1.0" />
      <initdata>
        <calcite_ca>
          <full_name>Ca as finely ground Agricultural Lime</full_name>
          <components>CaCO3</components>
          <fraction description="The weight of the Ca component of the lime.">1.0   </fraction>
        </calcite_ca>
        <calcite_fine>
          <full_name>finely ground Agricultural Lime</full_name>
          <components>CaCO3</components>
          <fraction description="The weight of the Ca component of the calcite.">0.4   </fraction>
        </calcite_fine>
        <cropDAP>
          <full_name>cropDAP</full_name>
          <components>nh4 labile_p so4</components>
          <fraction>  0.18   0.20   0.0 </fraction>
        </cropDAP>
        <dolomite>
          <full_name>finely ground dolomite</full_name>
          <components>CaCO3</components>
          <fraction description="The weight of the Ca component of the dolomite">0.22   </fraction>
        </dolomite>
        <NO3_N>
          <full_name>N as nitrate</full_name>
          <components>no3</components>
          <fraction>1.0</fraction>
        </NO3_N>
        <NH4_N>
          <full_name>N as ammonium</full_name>
          <components>nh4</components>
          <fraction>1.0</fraction>
        </NH4_N>
        <NH4NO3>
          <full_name>ammonium nitrate</full_name>
          <components>nh4  no3</components>
          <fraction>0.5  0.5</fraction>
        </NH4NO3>
        <DAP>
          <full_name>di-ammonium phosphate</full_name>
          <components>nh4 </components>
          <fraction>0.18</fraction>
        </DAP>
        <nitrophoska>
          <full_name>Nitrophoska TE</full_name>
          <components>nh4 no3</components>
          <fraction>0.045 0.075 </fraction>
        </nitrophoska>
        <MAP>
          <full_name>mono-ammonium phosphate</full_name>
          <components>nh4 </components>
          <fraction>0.11</fraction>
        </MAP>
        <urea_N>
          <full_name>N as urea</full_name>
          <components>urea</components>
          <fraction>1.0</fraction>
        </urea_N>
        <urea_no3>
          <full_name>N as urea</full_name>
          <components>urea no3</components>
          <fraction>0.50 0.50</fraction>
        </urea_no3>
        <urea>
          <full_name>Urea ferilizer</full_name>
          <components>urea</components>
          <fraction>0.46</fraction>
        </urea>
        <UAN_N>
          <full_name>N as Urea-AmmoniumNitrate</full_name>
          <components>urea nh4 no3</components>
          <fraction>0.5 0.25 0.25</fraction>
        </UAN_N>
        <nh4so4_n>
          <full_name>ammonium sulphate</full_name>
          <components>nh4</components>
          <fraction>1.0</fraction>
        </nh4so4_n>
        <rock_p>
          <full_name>Rock Phosphorus</full_name>
          <components>rock_p labile_p</components>
          <fraction>0.8     0.2</fraction>
        </rock_p>
        <banded_p>
          <full_name>Banded Phosphorus</full_name>
          <components>banded_p</components>
          <fraction>1.0</fraction>
        </banded_p>
        <broadcast_p>
          <full_name>Broadcast Phosporus</full_name>
          <components>labile_p</components>
          <fraction>1.0</fraction>
        </broadcast_p>
      </initdata>
    </component>
    <component name="Irrigation" executable="%apsim%\Model\Irrigation.dll" class="Irrigation">
      <executable name="%apsim%\Model\Irrigation.dll" version="1.0" />
      <initdata>
        <automatic_irrigation type="list" listvalues="on,off" description="Automatic irrigation">on</automatic_irrigation>
        <asw_depth type="text" description="Depth to which ASW is calculated. (mm)">800</asw_depth>
        <crit_fr_asw type="text" description="Fraction of ASW below which irrigation is applied (0-1.0)">0.65</crit_fr_asw>
        <irrigation_efficiency type="text" description="Efficiency of the irrigation. (0-1.0)">0.85</irrigation_efficiency>
        <irrigation_allocation type="list" listvalues="on,off" description="Allocation limits">off</irrigation_allocation>
        <allocation type="text" description="Allocation in mm">0</allocation>
        <default_no3_conc type="text" description="Nitrate concentration (ppm N)">0</default_no3_conc>
        <default_nh4_conc type="text" description="Ammonium concentration (ppm N)">0</default_nh4_conc>
        <default_cl_conc type="text" description="Chloride concentration (ppm Cl)">0.0</default_cl_conc>
        <solutes>nh4 no3 cl</solutes>
      </initdata>
    </component>
    <component name="wheat Fertilise in a zadok stage window" executable="%apsim%\Model\Manager.dll" class="Manager">
      <executable name="%apsim%\Model\Manager.dll" version="1.0" />
      <initdata>
        <ui>
          <category type="category" description="When should fertiliser be applied" />
          <zadok_fert_stage_begin type="text" description="Enter start of zadok window (10-71):   ">30</zadok_fert_stage_begin>
          <zadok_fert_stage_end type="text" description="Enter end of zadok window (10-71):   ">32</zadok_fert_stage_end>
          <fert_criteria type="text" description="Don't add fertiliser if N in top 2 layers exceeds (kg/ha) : ">1000</fert_criteria>
          <esw_amount type="text" description="Enter amount of soil water (mm)">50</esw_amount>
          <category type="category" description="Fertiliser application details" />
          <fertmodule type="modulename" description="Module used to apply the fertiliser : ">wheat</fertmodule>
          <fert_amount type="text" description="Amount of fertiliser to apply (kg/ha) : ">200</fert_amount>
          <fert_type type="list" listvalues="NO3_N, NH4_N, NH4NO3, UAN_N, urea_N, urea_no3, urea, nh4so4_n, rock_p, banded_p, broadcast_p" description="Fertiliser type : ">urea_N</fert_type>
        </ui>
        <script>
          <text>
            fert_applied[zadok_fert_stage_begin][zadok_fert_stage_end] = 0
    </text>
          <event>init</event>
        </script>
        <script>
          <text>
            fert_applied[zadok_fert_stage_begin][zadok_fert_stage_end] = 0
    </text>
          <event>sowing</event>
        </script>
        <script>
          <text>
         if (zadok_stage &gt;= [zadok_fert_stage_begin]
            AND zadok_stage &lt;= [zadok_fert_stage_end]
            AND fert_applied[zadok_fert_stage_begin][zadok_fert_stage_end] = 0) then
            if (esw &gt;= [esw_amount]) then
               N_topsoil = no3(1) + nh4(1) + no3(2) + nh4(2)
               if (N_topsoil &lt; [fert_criteria]) then
                  [fertmodule] apply amount = [fert_amount] (kg/ha), depth = 50 (mm), type = [fert_type] ()
               fert_applied[zadok_fert_stage_begin][zadok_fert_stage_end] = 1
               endif
            endif
         endif
         </text>
          <event>start_of_day</event>
        </script>
      </initdata>
    </component>
