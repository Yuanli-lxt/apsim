------- paddock.wheat Fertilise in a zadok stage window Initialisation --------
     Manager rules:
     
     SECTION:- init
     fert_applied3032 = 0
     
     SECTION:- sowing
     fert_applied3032 = 0
     
     SECTION:- start_of_day
              if (zadok_stage >= 30
     and zadok_stage <= 32
     and fert_applied3032 = 0) then
     if (esw >= 50) then
        n_topsoil = no3(1) + nh4(1) + no3(2) + nh4(2)
        if (n_topsoil < 1000) then
           wheat apply amount = 200 (kg/ha), depth = 50 (mm), type = urea_n ()
        fert_applied3032 = 1
        endif
     endif
              endif
     END of rules
     
     Manager creating a new local real variable : fert_applied3032 = 0.00000

------- paddock.wheat Fertilise in a zadok stage window1 Initialisation -------
     Manager rules:
     
     SECTION:- init
     fert_applied4549 = 0
     
     SECTION:- sowing
     fert_applied4549 = 0
     
     SECTION:- start_of_day
              if (zadok_stage >= 45
     and zadok_stage <= 49
     and fert_applied4549 = 0) then
     if (esw >= 50) then
        n_topsoil = no3(1) + nh4(1) + no3(2) + nh4(2)
        if (n_topsoil < 1000) then
           wheat apply amount = 20 (kg/ha), depth = 50 (mm), type = urea_n ()
        fert_applied4549 = 1
        endif
     endif
              endif
     END of rules
     
     Manager creating a new local real variable : fert_applied4549 = 0.00000

------- paddock.wheat Fertilise in a zadok stage window2 Initialisation -------
     Manager rules:
     
     SECTION:- init
     fert_applied1517 = 0
     
     SECTION:- sowing
     fert_applied1517 = 0
     
     SECTION:- start_of_day
              if (zadok_stage >= 15
     and zadok_stage <= 17
     and fert_applied1517 = 0) then
     if (esw >= 50) then
        n_topsoil = no3(1) + nh4(1) + no3(2) + nh4(2)
        if (n_topsoil < 1000) then
           maize apply amount = 20 (kg/ha), depth = 50 (mm), type = urea_n ()
        fert_applied1517 = 1
        endif
     endif
              endif
     END of rules
     
     Manager creating a new local real variable : fert_applied1517 = 0.00000

